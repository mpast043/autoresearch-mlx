# Recommended low-cost default: keep the relay hosted on Render and run the pipeline locally or in Codespaces.
REDDIT_BRIDGE_BASE_URL=https://autoresearch-relay.onrender.com
REDDIT_BRIDGE_AUTH_TOKEN=replace-with-your-render-relay-token

# Optional local relay token if you want to run `python3 cli.py reddit-relay` inside the Codespace instead.
REDDIT_RELAY_AUTH_TOKEN=replace-with-a-local-relay-token
