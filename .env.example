# Reddit Bridge (hosted relay)
REDDIT_BRIDGE_BASE_URL=https://autoresearch-relay.onrender.com
REDDIT_BRIDGE_AUTH_TOKEN=replace-with-your-render-relay-token
REDDIT_RELAY_AUTH_TOKEN=replace-with-a-local-relay-token

# LLM Provider (for BuilderV2 - optional, see requirements-optional.txt)
ANTHROPIC_API_KEY=sk-ant-

# Web Discovery (optional)
TAVILY_API_KEY=

# YouTube (optional)
YOUTUBE_API_KEY=

# GitHub (optional)
GITHUB_TOKEN=

# Apify for competitor intel (optional, see requirements-optional.txt)
APIFY_API_KEY=

# RAG embedding model (optional, see requirements-optional.txt)
EMBED_MODEL=all-MiniLM-L6-v2